rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function getUserRole() {
      return exists(/databases/$(database)/documents/users/$(request.auth.uid)) ? 
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role : null;
    }
    
    function isAdmin() {
      return isAuthenticated() && getUserRole() == 'admin';
    }
    
    function isDoctor() {
      return isAuthenticated() && getUserRole() == 'doctor';
    }
    
    function isNewUser() {
      return isAuthenticated() && !exists(/databases/$(database)/documents/users/$(request.auth.uid));
    }
    
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    // Admin access to all collections
    match /{document=**} {
      allow read, write: if isAdmin();
    }

    // Products
    match /products/{productId} {
      allow read: if true;
      allow write, create: if isAuthenticated();
    }

    // Users
    match /users/{userId} {
      allow read: if isAuthenticated();
      allow write: if isOwner(userId) || isAdmin();
      allow create: if isAuthenticated() && request.auth.uid == userId;

      match /favorites/{productId} {
        allow read, write: if isOwner(userId);
      }
      match /cart/{cartId} {
        allow read, write: if isOwner(userId);
      }
    }

    // Chats
    match /chats/{chatId} {
      allow read, write: if isAuthenticated() && 
        request.auth.uid in resource.data.participants;
      allow create: if isAuthenticated() && 
        request.auth.uid in request.resource.data.participants;
    }
    
    // Messages (top-level collection)
    match /messages/{messageId} {
      allow read, write: if isAuthenticated();
      allow create: if isAuthenticated();
    }

    // Support tickets
    match /support_tickets/{ticketId} {
      allow read: if isAuthenticated() && 
        (request.auth.uid == resource.data.userId || isAdmin());
      allow write: if isAuthenticated() && 
        (request.auth.uid == resource.data.userId || isAdmin());
      allow create: if isAuthenticated();
      allow list: if isAdmin();
    }

    // Orders
    match /orders/{orderId} {
      allow read: if isAuthenticated() && 
        (request.auth.uid == resource.data.userId || isAdmin() || isDoctor());
      allow write: if isAuthenticated() && 
        (request.auth.uid == resource.data.userId || isAdmin());
      allow create: if isAuthenticated() && 
        request.auth.uid == request.resource.data.userId;
    }

    // Posts
    match /posts/{postId} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated() && 
        (request.auth.uid == resource.data.userId || isAdmin());
      allow create: if isAuthenticated();
      
      // Comments subcollection
      match /comments/{commentId} {
        allow read: if isAuthenticated();
        allow write: if isAuthenticated() && 
          (request.auth.uid == resource.data.userId || isAdmin());
        allow create: if isAuthenticated();
      }
    }

    // Clinics
    match /clinics/{clinicId} {
      allow read: if true;
      allow write: if isAuthenticated() && 
        (isAdmin() || isDoctor() || request.auth.uid == resource.data.doctorId);
      allow create: if isAuthenticated() && 
        (isAdmin() || isDoctor() || request.auth.uid == request.resource.data.doctorId);
    }

    // Reservations
    match /reservations/{reservationId} {
      allow read, write: if isAuthenticated() && 
        (request.auth.uid == resource.data.userId || 
         request.auth.uid == resource.data.doctorId || 
         isAdmin());
      allow create: if isAuthenticated();
    }

    // Bookings
    match /bookings/{bookingId} {
      allow read, write: if isAuthenticated() && 
        (request.auth.uid == resource.data.doctorId || 
         request.auth.uid == resource.data.userId ||
         isAdmin());
      allow create: if isAuthenticated();
    }

    // Notifications
    match /notifications/{notificationId} {
      allow read: if isAuthenticated() && 
        (request.auth.uid == resource.data.userId || isAdmin());
      allow write: if isAuthenticated() && 
        (request.auth.uid == resource.data.userId || isAdmin());
      allow create: if isAuthenticated();
    }

    // Support statistics
    match /support_stats/{statId} {
      allow read: if isAdmin();
      allow write: if isAdmin();
    }

    // Admin-only
    match /admin_settings/{doc} {
      allow read, write: if isAdmin();
    }
    match /system_logs/{logId} {
      allow read, write: if isAdmin();
    }
  }
}
